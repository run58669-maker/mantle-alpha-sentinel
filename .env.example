# DeepSeek via DashScope (Alibaba Cloud International)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=deepseek-v4-pro

# Optional — Telegram alert feed. Create a bot via @BotFather, then set both.
# Leave blank to run console-only (no alerts pushed).
TG_BOT_TOKEN=
TG_CHAT_ID=
